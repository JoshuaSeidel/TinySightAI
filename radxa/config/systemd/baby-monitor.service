[Unit]
Description=Camera Streamer (ustreamer)
# Can start as soon as /dev/video0 exists — no network dependency
ConditionPathExists=/dev/video0

[Service]
Type=simple
ExecStart=/opt/aadongle/bin/ustreamer --device /dev/video0 --host 0.0.0.0 --port 8082 --resolution 1920x1080 --format MJPEG --desired-fps 30
Restart=always
RestartSec=2
User=root

[Install]
WantedBy=aadongle.target
