[Unit]
Description=Watchdog + Power Monitor
# Starts in parallel with everything else — just sets governor and monitors
After=basic.target

[Service]
Type=simple
ExecStart=/opt/aadongle/scripts/power-manager.sh
Restart=always
RestartSec=5
User=root
StandardOutput=journal
StandardError=journal
SyslogIdentifier=power-manager

[Install]
WantedBy=aadongle.target
